# 1. Load the NetCDF file as a SpatRaster object
sst_raster <- terra::rast("oisst_monthly_1981_2026.nc")
# 1. Load the NetCDF file as a SpatRaster object
sst_raster <- terra::rast(")1_inputs/oisst_monthly_1981_2026.nc")
# 1. Load the NetCDF file as a SpatRaster object
sst_raster <- terra::rast("01_inputs/oisst_monthly_1981_2026.nc")
# 2. Extract the dates/times from the NetCDF metadata
dates <- terra::time(sst_raster)
# 3. Extract just the month number (1 to 12) from those dates
months <- as.numeric(format(dates, "%m"))
# 4. Create a logical mask for September (9) through April (4)
keep_months <- months %in% c(9, 10, 11, 12, 1, 2, 3, 4)
# 5. Subset the raster layers based on that mask
filtered_sst <- terra::sst_raster[[keep_months]]
# 5. Subset the raster layers based on that mask
filtered_sst <- sst_raster[[keep_months]]
# 6. Write the filtered data back out to a NetCDF file
writeCDF(filtered_sst,
filename = "02_intermediates/oisst_sep_apr_1981_2026.nc",
name = "sst", # Change this to your actual variable name if it's not 'sst'
overwrite = TRUE)
# 6. Write the filtered data back out to a NetCDF file
terra::writeCDF(filtered_sst,
filename = "02_intermediates/oisst_sep_apr_1981_2026.nc",
name = "sst", # Change this to your actual variable name if it's not 'sst'
overwrite = TRUE)
sst_converted <- EDABUtilities::convert_2d_longitude_gridded(data = here::here('02_intermediates','oisst_sep_apr_1981_2026.nc'))
sst_filtered <- EDABUtilities::convert_2d_longitude_gridded(data = here::here('02_intermediates','oisst_sep_apr_1981_2026.nc'))
data <- EDABUtilities::make_2d_deg_day_ts(
data.in = sst_filtered,
var.name = "sst",
statistic = "nd",
ref.value = 8,
type = "below",
shp.file = species_shp,
area.names = "stock_area",
write.out = FALSE
)
