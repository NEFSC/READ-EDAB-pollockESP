bt_data <- read.csv(url1) |>
dplyr::bind_rows(read.csv(url2)) |>
dplyr::mutate(
SEASON = dplyr::case_when(
MONTH %in% c(1, 2, 3)    ~ "Winter",
MONTH %in% c(4, 5, 6)    ~ "Spring",
MONTH %in% c(7, 8, 9)    ~ "Summer",
MONTH %in% c(10, 11, 12) ~ "Fall"
)
) |>
dplyr::group_by(AREA, SEASON, YEAR, INDICATOR_NAME, INDICATOR_UNITS) |>
dplyr::summarise(DATA_VALUE = mean(DATA_VALUE, na.rm = TRUE), .groups = "drop") |>
dplyr::mutate(INDICATOR_NAME = "seasonal_bottomT")
ggplot2::ggplot(bt_data, ggplot2::aes(x = YEAR, y = DATA_VALUE, group = SEASON)) +
ggplot2::geom_line(ggplot2::aes(color = SEASON), size = 1) +
ggplot2::geom_point(ggplot2::aes(color = SEASON), size = 2) +
ggplot2::facet_grid(. ~ SEASON) +
ggplot2::labs(
title = "Bottom Temperature by Season in Pollock Stock Area",
x = "Year",
y = "Temperature (°C)",
color = "Season"
) +
ggplot2::theme_minimal() +
ggplot2::theme(
strip.text = element_text(face = "bold", size = 12),
legend.position = "none"
)
